{
  "properties": {
    "connectionReferences": {
      "shared_office365": {
        "api": {
          "name": "shared_office365"
        },
        "connection": {
          "connectionReferenceLogicalName": "new_sharedoffice365_e1f29"
        },
        "runtimeSource": "embedded"
      }
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "contentVersion": "undefined",
      "parameters": {
        "$authentication": {
          "defaultValue": {},
          "type": "SecureObject"
        },
        "$connections": {
          "defaultValue": {},
          "type": "Object"
        }
      },
      "triggers": {
        "Recurrence": {
          "type": "Recurrence",
          "recurrence": {
            "frequency": "Day",
            "interval": "1",
            "startTime": "2026-06-09T01:00:00Z"
          }
        }
      },
      "actions": {
        "alertContent": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "alertContent",
                "type": "string",
                "value": "<table border=\"1\" cellpadding=\"6\" cellspacing=\"0\"><tr><th>監控類別</th><th>監控項目</th><th>狀態</th><th>異常程度</th></tr>\n"
              }
            ]
          },
          "runAfter": {}
        },
        "anomalyCount": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "anomalyCount",
                "type": "integer",
                "value": 0
              }
            ]
          },
          "runAfter": {
            "alertContent": [
              "Succeeded"
            ]
          }
        },
        "套用至各項": {
          "type": "Foreach",
          "foreach": "@outputs('BUDGET_OVERSPEND_MockData')?['results']\r\n",
          "actions": {
            "campaignDays": {
              "type": "Compose",
              "inputs": "@max(1, div(sub(ticks(item()?['campaign']?['endDate']), ticks(item()?['campaign']?['startDate'])), 864000000000))\r\n"
            },
            "expectedDaily": {
              "type": "Compose",
              "inputs": "@div(int(item()?['campaignBudget']?['amountMicros']), 1000000)\r\n",
              "runAfter": {
                "campaignDays": [
                  "Succeeded"
                ]
              }
            },
            "條件_1": {
              "type": "If",
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@greater(outputs('actualCumCostNT'), mul(outputs('expectedCumNT'), 1.1))\r\n",
                      true
                    ]
                  }
                ]
              },
              "actions": {
                "遞增變數_1": {
                  "type": "IncrementVariable",
                  "inputs": {
                    "name": "anomalyCount",
                    "value": 1
                  }
                },
                "附加至字串變數_1": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "alertContent",
                    "value": "<tr><td>廣告累積花費異常</td><td>@{item()?['campaign']?['name']} 累積花費 NT$@{first(split(string(outputs('actualCumCostNT')), '.'))} 超出預算門檻 NT$@{first(split(string(mul(outputs('expectedCumNT'), 1.1)), '.'))}（超標 +@{first(split(string(sub(div(mul(outputs('actualCumCostNT'), 100), mul(outputs('expectedCumNT'), 1.1)), 100)), '.'))}%）</td><td>異常</td><td>高</td></tr>\n"
                  },
                  "runAfter": {
                    "遞增變數_1": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "else": {
                "actions": {}
              },
              "runAfter": {
                "expectedCumNT": [
                  "Succeeded"
                ]
              }
            },
            "actualCumCostNT": {
              "type": "Compose",
              "inputs": "@div(int(item()?['metrics']?['costMicros']), 1000000)",
              "runAfter": {
                "expectedDaily": [
                  "Succeeded"
                ]
              }
            },
            "dailyExpectedNT": {
              "type": "Compose",
              "inputs": "@div(outputs('expectedDaily'), outputs('campaignDays'))",
              "runAfter": {
                "actualCumCostNT": [
                  "Succeeded"
                ]
              }
            },
            "elapsedDays": {
              "type": "Compose",
              "inputs": "@min(outputs('campaignDays'), max(1, div(sub(ticks(utcNow()), ticks(item()?['campaign']?['startDate'])), 864000000000)))\r\n",
              "runAfter": {
                "dailyExpectedNT": [
                  "Succeeded"
                ]
              }
            },
            "expectedCumNT": {
              "type": "Compose",
              "inputs": "@mul(outputs('dailyExpectedNT'), outputs('elapsedDays'))",
              "runAfter": {
                "elapsedDays": [
                  "Succeeded"
                ]
              }
            }
          },
          "runAfter": {
            "BUDGET_OVERSPEND_MockData": [
              "Succeeded"
            ]
          }
        },
        "條件_2": {
          "type": "If",
          "expression": {
            "or": [
              {
                "greater": [
                  "@outputs('ctrChangeRate')",
                  0.2
                ]
              },
              {
                "less": [
                  "@outputs('ctrChangeRate')",
                  -0.2
                ]
              }
            ]
          },
          "actions": {
            "遞增變數_2": {
              "type": "IncrementVariable",
              "inputs": {
                "name": "anomalyCount",
                "value": 1
              }
            },
            "CTR": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "alertContent",
                "value": "<tr><td>CTR 成效異常</td><td>CampaignID ：@{first(body('todayResults'))?['campaign']?['name']}</td><td>異常</td><td>\n@{concat(first(split(string(mul(outputs('ctrChangeRate'), 100)), '.')), '%')\r\n}</td></tr>"
              },
              "runAfter": {
                "遞增變數_2": [
                  "Succeeded"
                ]
              }
            }
          },
          "else": {
            "actions": {}
          },
          "runAfter": {
            "ctrChangeRate": [
              "SUCCEEDED"
            ]
          }
        },
        "targetCPA": {
          "type": "Compose",
          "inputs": 500,
          "runAfter": {
            "SEM_HIGH_CPA_MockData": [
              "Succeeded"
            ]
          }
        },
        "條件_3": {
          "type": "If",
          "expression": {
            "and": [
              {
                "greater": [
                  "@length(body('highCPAKeywords'))",
                  0
                ]
              }
            ]
          },
          "actions": {
            "遞增變數_3": {
              "type": "IncrementVariable",
              "inputs": {
                "name": "anomalyCount",
                "value": 1
              }
            },
            "SEM": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "alertContent",
                "value": "<tr><td>SEM 差勁關鍵字</td><td>CampaignID：@{first(body('highCPAKeywords'))?['campaign']?['id']} / AdGroup：@{first(body('highCPAKeywords'))?['adGroup']?['name']}</td><td>異常</td><td>SEM差勁關鍵字附件.csv</td></tr>\n"
              },
              "runAfter": {
                "遞增變數_3": [
                  "Succeeded"
                ]
              }
            },
            "建立_CSV_資料表": {
              "type": "Table",
              "inputs": {
                "from": "@body('選取')",
                "format": "CSV"
              },
              "runAfter": {
                "選取": [
                  "Succeeded"
                ]
              }
            },
            "選取": {
              "type": "Select",
              "inputs": {
                "from": "@body('highCPAKeywords')",
                "select": {
                  "Campaign": "@item()?['campaign']?['name']",
                  "AdGroup": "@\titem()?['adGroup']?['name']",
                  "Keyword": "@item()?['adGroupCriterion']?['keyword']?['text']",
                  "MatchType": "@item()?['adGroupCriterion']?['keyword']?['matchType']",
                  "CostMicros": "@item()?['metrics']?['costMicros']",
                  "Conversions": "@item()?['metrics']?['conversions']",
                  "CostPerConversion": "@item()?['metrics']?['costPerConversion']"
                }
              },
              "runAfter": {
                "SEM": [
                  "Succeeded"
                ]
              }
            },
            "附加至字串變數_5": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "alertContent",
                "value": "</table><br><br><strong>【SEM 差勁關鍵字明細】</strong><table border=\"1\" style=\"border-collapse:collapse\"><tr><th>Campaign</th><th>AdGroup</th><th>關鍵字</th><th>比對類型</th><th>CPA (NT$)</th></tr>\n"
              },
              "runAfter": {
                "建立_CSV_資料表": [
                  "Succeeded"
                ]
              }
            },
            "套用至各項_1": {
              "type": "Foreach",
              "foreach": "@body('highCPAKeywords')",
              "actions": {
                "每筆關鍵字": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "alertContent",
                    "value": "<tr><td>@{item()?['campaign']?['id']}</td><td>@{item()?['adGroup']?['name']}</td><td>@{item()?['adGroupCriterion']?['keyword']?['text']}</td><td>@{item()?['adGroupCriterion']?['keyword']?['matchType']}</td><td>@{item()?['metrics']?['costPerConversion']}</td></tr>\n"
                  }
                }
              },
              "runAfter": {
                "附加至字串變數_5": [
                  "Succeeded"
                ]
              }
            }
          },
          "else": {
            "actions": {}
          },
          "runAfter": {
            "highCPAKeywords": [
              "Succeeded"
            ]
          }
        },
        "條件_4": {
          "type": "If",
          "expression": {
            "and": [
              {
                "greater": [
                  "@int(variables('anomalyCount'))",
                  0
                ]
              }
            ]
          },
          "actions": {
            "傳送電子郵件_(V2)": {
              "type": "OpenApiConnection",
              "inputs": {
                "parameters": {
                  "emailMessage/To": "Yeega@YeeGa.onmicrosoft.com",
                  "emailMessage/Subject": "@{concat('[Google Ads 異常監控] ', formatDateTime(utcNow(), 'yyyy/MM/dd'), ' 發現 ', string(variables('anomalyCount')), ' 組異常')}\n",
                  "emailMessage/Body": "<p class=\"editor-paragraph\">最近監控時間為 @{formatDateTime(utcNow(), 'yyyyMMdd')}，發現 @{variables('anomalyCount')} 組異常情況。</p><p class=\"editor-paragraph\"><br>@{variables('alertContent')}</p><br><p class=\"editor-paragraph\">此信件由系統自動產生，請勿回覆。</p><br>",
                  "emailMessage/Attachments": [
                    {
                      "Name": "SEM差勁關鍵字附件.csv",
                      "ContentBytes": "@concat(decodeUriComponent('%EF%BB%BF'), body('建立_CSV_資料表'))"
                    }
                  ],
                  "emailMessage/Importance": "Normal"
                },
                "host": {
                  "apiId": "/providers/Microsoft.PowerApps/apis/shared_office365",
                  "operationId": "SendEmailV2",
                  "connectionName": "shared_office365"
                }
              }
            }
          },
          "else": {
            "actions": {}
          },
          "runAfter": {
            "關閉明細表": [
              "SUCCEEDED"
            ]
          }
        },
