                }
              },
              {
                "campaign": {
                  "id": "3333",
                  "name": "2026_Brand_TW",
                  "status": "ENABLED"
                },
                "metrics": {
                  "ctr": 0.038
                },
                "segments": {
                  "date": "@{formatDateTime(addDays(utcNow(), -1), 'yyyy-MM-dd')}"
                }
              },
              {
                "campaign": {
                  "id": "3333",
                  "name": "2026_Brand_TW",
                  "status": "ENABLED"
                },
                "metrics": {
                  "ctr": 0.021
                },
                "segments": {
                  "date": "@{formatDateTime(utcNow(), 'yyyy-MM-dd')}"
                }
              }
            ]
          },
          "runAfter": {
            "套用至各項": [
              "Succeeded"
            ]
          }
        },
