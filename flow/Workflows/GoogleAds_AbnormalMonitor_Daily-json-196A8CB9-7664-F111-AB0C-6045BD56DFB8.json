            ]
          }
        },
        "ctrDiffToday": {
          "type": "Compose",
          "inputs": "@sub(mul(float(first(body('todayResults'))?['metrics']?['ctr']), 10000), mul(float(first(body('yesterdayResults'))?['metrics']?['ctr']), 10000))",
          "runAfter": {
