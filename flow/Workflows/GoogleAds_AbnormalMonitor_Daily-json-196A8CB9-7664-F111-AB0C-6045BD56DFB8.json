                  "Succeeded"
                ]
              }
            }
          },
          "else": {
            "actions": {}
          },
          "runAfter": {
            "篩選陣列_1": [
              "Succeeded"
            ]
          }
        },
        "todayResults": {
          "type": "Query",
          "inputs": {
            "from": "@outputs('CTR_FLUCTUATION_MockData')?['results']",
            "where": "@equals(item()?['segments']?['date'],formatDateTime(utcNow(), 'yyyy-MM-dd'))"
          },
          "runAfter": {
            "CTR_FLUCTUATION_MockData": [
              "Succeeded"
            ]
          }
        },
        "yesterdayResults": {
          "type": "Query",
          "inputs": {
            "from": "@outputs('CTR_FLUCTUATION_MockData')?['results']",
            "where": "@equals(item()?['segments']?['date'],addDays(utcNow(), -1, 'yyyy-MM-dd'))"
          },
          "runAfter": {
            "todayResults": [
              "Succeeded"
            ]
          }
        },
        "dayBeforeResults": {
          "type": "Query",
          "inputs": {
            "from": "@outputs('CTR_FLUCTUATION_MockData')?['results']",
            "where": "@equals(item()?['segments']?['date'],addDays(utcNow(), -2, 'yyyy-MM-dd'))"
          },
          "runAfter": {
            "yesterdayResults": [
              "Succeeded"
            ]
          }
        },
        "highCPAKeywords": {
          "type": "Query",
          "inputs": {
            "from": "@outputs('SEM_HIGH_CPA_MockData')?['results']",
            "where": "@or(greater(item()?['metrics']?['costPerConversion'], mul(outputs('targetCPA'), 1.2)), and(less(item()?['metrics']?['conversions'], 1), greater(float(item()?['metrics']?['costMicros']), 0)))"
