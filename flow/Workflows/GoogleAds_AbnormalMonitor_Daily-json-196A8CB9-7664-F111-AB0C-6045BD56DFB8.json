            "fieldMask": "campaign.id,campaign.name,campaign.status,campaign.start_date,campaign.end_date,campaign_budget.amount_micros,metrics.cost_micros",
            "requestId": "mock-campaign-cumulative-20260601"
          },
          "runAfter": {
            "條件": [
              "Succeeded"
            ]
          }
        },
        "CTR_FLUCTUATION_MockData": {
          "type": "Compose",
          "inputs": {
            "results": [
              {
                "campaign": {
                  "id": "3333",
                  "name": "2026_Brand_TW",
                  "status": "ENABLED"
                },
                "metrics": {
                  "ctr": 0.035
                },
                "segments": {
