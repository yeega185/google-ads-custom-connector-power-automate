        "篩選陣列": {
          "type": "Query",
          "inputs": {
            "from": "@outputs('COST_ZERO_MockData')?['results']",
            "where": "@equals(item()?['metrics']?['costMicros'],0)"
          },
          "runAfter": {
            "COST_ZERO_MockData": [
              "Succeeded"
            ]
          }
        },
        "篩選陣列_1": {
          "type": "Query",
          "inputs": {
            "from": "@body('篩選陣列')\r\n",
            "where": "@less(item()?['campaign']?['startDate'],addDays(utcNow(), -2, 'yyyy-MM-dd'))"
          },
          "runAfter": {
            "篩選陣列": [
              "Succeeded"
            ]
          }
        },
        "條件": {
          "type": "If",
          "expression": {
            "and": [
              {
                "greater": [
                  "@length(body('篩選陣列_1'))",
                  0
                ]
              }
            ]
          },
          "actions": {
            "遞增變數": {
              "type": "IncrementVariable",
              "inputs": {
                "name": "anomalyCount",
                "value": 1
              }
            },
            "附加至字串變數": {
              "type": "AppendToStringVariable",
              "inputs": {
                "name": "alertContent",
                "value": "<tr><td>花費異常 COST ZERO</td><td>近48小時上線活動有Cost為零</td><td>異常</td><td>花費 = 0</td></tr>\n"
              },
