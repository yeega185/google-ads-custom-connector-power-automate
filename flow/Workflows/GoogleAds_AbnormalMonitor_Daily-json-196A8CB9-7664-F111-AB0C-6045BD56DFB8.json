              "SUCCEEDED"
            ]
          }
        },
        "ctrDiffYesterday": {
          "type": "Compose",
          "inputs": "@sub(mul(float(first(body('yesterdayResults'))?['metrics']?['ctr']), 10000), mul(float(first(body('dayBeforeResults'))?['metrics']?['ctr']), 10000))",
          "runAfter": {
            "ctrDiffToday": [
              "SUCCEEDED"
            ]
          }
        },
        "ctrChangeRate": {
          "type": "Compose",
          "inputs": "@if(equals(float(outputs('ctrDiffYesterday')), 0), 0, div(float(outputs('ctrDiffToday')), float(outputs('ctrDiffYesterday'))))",
          "runAfter": {
            "ctrDiffYesterday": [
              "SUCCEEDED"
            ]
          }
