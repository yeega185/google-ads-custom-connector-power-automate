            "fieldMask": "campaign.id,campaign.name,campaign.status,campaign.start_date,campaign.end_date,metrics.cost_micros,metrics.impressions,metrics.clicks,metrics.ctr,metrics.conversions,segments.date",
            "requestId": "mock-campaign-today-20260601"
          },
          "runAfter": {
            "anomalyCount": [
              "Succeeded"
